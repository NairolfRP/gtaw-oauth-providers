{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NairolfRP/gtaw-oauth-providers.git"
  },
  "description": "Some GTA World OAuth providers for some frameworks and libraries. ",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "lint": "eslint --cache .",
    "format": "prettier --cache -c .",
    "format:write": "prettier --cache --write .",
    "release": "pnpm build && pnpm -r --workspace-concurrency=1 exec -- npx --no-install semantic-release -e semantic-release-monorepo",
    "release:dry": "pnpm build && pnpm -r --workspace-concurrency=1 exec -- npx --no-install semantic-release --dry-run -e semantic-release-monorepo"
  },
  "keywords": [],
  "author": {
    "name": "NairolfRP",
    "url": "https://github.com/NairolfRP"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/NairolfRP/gtaw-oauth-providers/issues"
  },
  "homepage": "https://github.com/NairolfRP/gtaw-oauth-providers",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
